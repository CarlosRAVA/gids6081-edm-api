generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(200)
  lastname String @db.VarChar(300)
  username String @db.VarChar(100)
  password String @db.LongText
  hash String? @db.LongText
  created_at DateTime@default(now())
  task Task[] //un usuario puede tener varias tareas
}

model Task {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(250)
  description String @db.VarChar(200)
  priority Boolean 
  created_at DateTime@default(now())
  user_id Int
  user User @relation(fields: [user_id], references: [id]) //se necesita declarar la relacion que tendra si sera de 1 a muchos o muchos a muchos
}